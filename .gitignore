.DS_Store

# Local secrets and credentials
.env
.env.*
!.env.example
*secret*
*credential*

# Local agent/editor state
.claude/
.context/
working-notes/

# Python
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# LaTeX build artifacts; keep source and final PDF.
paper/*.aux
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/*_fm4ls.*

# Generated run logs and bulky tool intermediates.
logs/
outputs/resfinder/*/resfinder_blast/tmp/
outputs/agent_trial_step*.md
outputs/mechreason_trial.md

# OS/editor noise
*.swp
*.swo
*~
